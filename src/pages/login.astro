---
import Layout from '@layouts/Layout.astro';
---

<Layout 
	title='Login' 
	description="Log in to Evolution YGO to track your stats and participate in tournaments."
	noindex={true}
	nofollow={true}
>
	<h1 class='text-gradient text-center'>Login</h1>
</Layout>
<style>
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0%;
	}
</style>
<script>
	import { getSession } from '@stores/sessionStore';
	import { toast } from 'sonner';

	if (sessionStorage.getItem('flash') === 'password-changed') {
		sessionStorage.removeItem('flash');
		toast.success('Password updated. Please log in with your new password.');
	}

	if (getSession().isLoggedIn) {
		window.location.href = '/';
	}else{
		const signinButton = document.getElementById("button-modal-signin");
		signinButton?.click();
	}
</script>