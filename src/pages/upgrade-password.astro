---
import Layout from '@layouts/Layout.astro';
import { UpgradePasswordForm } from '@components/Auth/UpgradePasswordForm';
---

<Layout
	title='Upgrade Password'
	description='Set a secure password for your Evolution YGO account.'
	noindex={true}
	nofollow={true}
>
	<div class='flex flex-col items-center justify-center min-h-[60vh] px-4'>
		<div class='w-full max-w-sm'>
			<p class='text-center text-xs font-semibold uppercase tracking-[0.2em] text-base-content/60 mb-2'>
				Account security
			</p>
			<h1 class='text-gradient text-center mb-4'>Secure your account</h1>
			<div role='note' class='alert bg-base-200 border border-base-300 text-sm text-left items-start gap-3 mb-6'>
				<svg
					viewBox='0 0 24 24'
					fill='none'
					stroke='currentColor'
					stroke-width='2'
					stroke-linecap='round'
					stroke-linejoin='round'
					aria-hidden='true'
					class='size-5 shrink-0 text-primary mt-0.5'
				>
					<path
						d='M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z'
					></path>
					<path d='m9 12 2 2 4-4'></path>
				</svg>
				<span>
					Your 4-character PIN stays as your game password for connecting from external
					clients to the Evolution server. Now set a strong account password for the web —
					your identity and stats stay the same.
				</span>
			</div>
			<UpgradePasswordForm client:only='react' />
		</div>
	</div>
</Layout>

<style>
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0%;
	}
</style>

<script>
	import { getSession } from '@stores/sessionStore';

	const { isLoggedIn, mustUpgrade } = getSession();

	if (!isLoggedIn) {
		window.location.replace('/login');
	} else if (!mustUpgrade) {
		window.location.replace('/');
	}
</script>
